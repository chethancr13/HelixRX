rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /vcf/{userId}/{fileName} {
      // Firebase-only bootstrap mode:
      // allow browser uploads without auth, but keep constraints tight.
      allow read: if true;
      // resource == null ensures create-only (no overwrite at same object path).
      allow write: if resource == null
                   && request.resource != null
                   && request.resource.size <= 5 * 1024 * 1024
                   && fileName.matches('.*\\.vcf$');
    }
  }
}